<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UnifiedAttestation.OpcUa.OnboardingApplication.MainWindow"
        xmlns:local="clr-namespace:UnifiedAttestation.OpcUa.OnboardingApplication"
        Title="UnifiedAttestation.OnboardingClient"
        Width="800" Height="600"
        MinWidth="500" MinHeight="400">

    <Window.Resources>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Window.Resources>

    <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <!-- Remote Attestation Tab -->
        <TabItem Header="Remote Attestation">
            <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <!-- Attestation Data Id -->
                <TextBlock Grid.Row="0" Text="Attestation Data Id"/>
                <NumericUpDown Grid.Row="1" Name="AttestationDataIdInput" Minimum="0" Maximum="100" Value="0"/>

                <!-- Attester Endpoint -->
                <TextBlock Grid.Row="2" Text="Attester Endpoint" Margin="0,8,0,0"/>
                <TextBox Grid.Row="3" Name="AttesterEndpointInput" Watermark="Enter attester endpoint" Text="opc.tcp://localhost:62541/"/>

                <!-- Verifier Endpoint -->
                <TextBlock Grid.Row="4" Text="Verifier Endpoint" Margin="0,8,0,0"/>
                <TextBox Grid.Row="5" Name="VerifierEndpointInput" Watermark="Enter verifier endpoint" Text="opc.tcp://localhost:62542/"/>

                <!-- Buttons row -->
                <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                    <Button Name="SubmitAttestationButton" Content="Submit" Click="RemoteAttestationSubmit_Click"/>
                    <Button Name="CancelAttestationButton" Content="Cancel" Click="CancelAttestation_Click" IsEnabled="False"/>
                    <ProgressBar Name="AttestationProgress" Width="80" Height="24" IsEnabled="False" IsVisible="False" IsIndeterminate="True"/>
                </StackPanel>

                <!-- Verifier Response (fills remaining space) -->
                <Border Grid.Row="7" BorderBrush="Gray" BorderThickness="1" Padding="5" CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Verifier Response" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl Name="VerifierEntries">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="local:TpmEntryCheckViewModel">
                                        <Border Margin="0,0,0,5" Padding="5" CornerRadius="3"
                                                Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PcrInfo}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding EventHex}" FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding ExpectedHex}" FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding ActualHex}" FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding StatusText}" FontStyle="Italic"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- Reference Value Management Tab -->
        <TabItem Header="Reference Value Management">
            <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <!-- Software Name -->
                <TextBlock Grid.Row="0" Text="Software Name"/>
                <TextBox Grid.Row="1" Name="SoftwareNameInput" Watermark="Enter software name"/>

                <!-- Version Number -->
                <TextBlock Grid.Row="2" Text="Version Number" Margin="0,8,0,0"/>
                <NumericUpDown Grid.Row="3" Name="SoftwareVersionInput" Minimum="0" Maximum="100" Value="0"/>

                <!-- Software Hash -->
                <TextBlock Grid.Row="4" Text="Software Hash (Hex Bytes)" Margin="0,8,0,0"/>
                <TextBox Grid.Row="5" Name="SoftwareHashInput"
                         Watermark="Enter bytes (e.g. 01 02 03 04)"
                         TextChanged="BytesInput_TextChanged"/>
                <TextBlock Grid.Row="6" Name="SoftwareHashError"
                           Foreground="Red" FontSize="12" IsVisible="False" Margin="0,2,0,0"/>

                <!-- Submit Button -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                    <Button Content="Submit" Click="SoftwareSubmit_Click"/>
                </StackPanel>

                <!-- Optional filler for flexible layout -->
                <Grid Grid.Row="8"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
