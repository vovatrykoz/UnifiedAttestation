<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UnifiedAttestation.Client.MainWindow"
        Title="UnifiedAttestation.Client">

  <TabControl>

    <TabItem Header="Remote Attestation">
      <StackPanel Margin="10" Spacing="8">

        <TextBlock Text="Attestation Data Id"/>
        <NumericUpDown Name="AttestationDataIdInput"
                       Minimum="0"
                       Maximum="100"
                       Value="0"/>

        <TextBlock Text="Attester Endpoint"/>
        <TextBox Name="AttesterEndpointInput"
                 Watermark="Enter attester endpoint"
                 Text = "opc.tcp://localhost:62541/"/>

        <TextBlock Text="Verifier Endpoint"/>
        <TextBox Name="VerifierEndpointInput"
                 Watermark="Enter verifier endpoint"
                 Text = "opc.tcp://localhost:62542/"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Name="SubmitAttestationButton" Content="Submit" Click="RemoteAttestationSubmit_Click"/>
            <Button Name="CancelAttestationButton" Content="Cancel" Click="CancelAttestation_Click" IsEnabled="False" />
            <ProgressBar Name="AttestationProgress" Width="80" Height="24" IsEnabled="False" IsVisible="False" IsIndeterminate="True"/>
        </StackPanel>

        <TextBlock Text="Verifier Response" FontWeight="Bold"/>
        <Border BorderBrush="Gray" BorderThickness="1" Padding="5" CornerRadius="3">
            <TextBlock Name="VerifierServerResponse" TextWrapping="Wrap"/>
        </Border>

      </StackPanel>
    </TabItem>

    <TabItem Header="Reference Value Management">
      <StackPanel Margin="10" Spacing="8">

        <TextBlock Text="Software Name"/>
        <TextBox Name="SoftwareNameInput"
                 Watermark="Enter software name"/>

        <TextBlock Text="Version Number"/>
        <NumericUpDown Name="SoftwareVersionInput"
                       Minimum="0"
                       Maximum="100"
                       Value="0"/>

        <TextBlock Text="Software Hash (Hex Bytes)"/>
        <TextBox Name="SoftwareHashInput"
                 Watermark="Enter bytes (e.g. 01 02 03 04)"
                 TextChanged="BytesInput_TextChanged"/>
        <TextBlock Name="SoftwareHashError"
                   Foreground="Red"
                   FontSize="12"
                   IsVisible="False"/>

        <Button Content="Submit" Click="SoftwareSubmit_Click"/>

      </StackPanel>
    </TabItem>

  </TabControl>
</Window>
