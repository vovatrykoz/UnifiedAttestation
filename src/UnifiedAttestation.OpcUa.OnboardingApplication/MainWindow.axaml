<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="UnifiedAttestation.OpcUa.OnboardingApplication.MainWindow"
        xmlns:local="clr-namespace:UnifiedAttestation.OpcUa.OnboardingApplication"
        Title="UnifiedAttestation.OnboardingClient"
        Width="800" Height="600"
        MinWidth="500" MinHeight="400">

    <Window.Resources>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <local:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

    <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <TabItem Header="Remote Attestation">
            <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="Attester Id"/>
                <ComboBox Grid.Row="1" Name="AttesterIdDropdown"/>

                <TextBlock Grid.Row="2" Text="Attester Endpoint" Margin="0,8,0,0"/>
                <Border Background="LightGray"
                    Grid.Row="3"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Padding="6"
                    CornerRadius="4">
                
                    <TextBlock Name="AttesterEndpointInput"/>
                            
                </Border>

                <TextBlock Grid.Row="4" Text="Verifier Endpoint" Margin="0,8,0,0"/>
                <TextBox Grid.Row="5" Name="VerifierEndpointInput" Watermark="Enter verifier endpoint" Text="opc.tcp://localhost:62542/"/>

                <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                    <Button Name="SubmitAttestationButton" Content="Submit" Click="RemoteAttestationSubmit_Click"/>
                    <Button Name="CancelAttestationButton" Content="Cancel" Click="CancelAttestation_Click" IsEnabled="False"/>
                    <Button Name="ClearAttestationDataButton" Content="Clear" Click="ClearAttestationDataButton_Click"/>
                    <ProgressBar Name="AttestationProgress" Width="80" Height="24" IsEnabled="False" IsVisible="False" IsIndeterminate="True"/>
                </StackPanel>

                <Border Grid.Row="7" BorderBrush="Gray" BorderThickness="1" Padding="5" CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Verifier Response Details" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl Name="StagesList" HorizontalAlignment="Stretch">
                                <ItemsControl.DataTemplates>
                                    <DataTemplate DataType="local:StageResultViewModel">
                                        <Expander IsExpanded="{Binding IsExpanded}" HorizontalAlignment="Stretch">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding StageName}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding StageResult, Converter={StaticResource BoolToStatusTextConverter}}"
                                                            Foreground="{Binding StageResult, Converter={StaticResource BoolToColorConverter}}"/>
                                                </StackPanel>
                                            </Expander.Header>
                                                
                                            <StackPanel>
                                                <TextBlock Text="{Binding ErrorMessage}" 
                                                    Foreground="{Binding StageResult, Converter={StaticResource BoolToColorConverter}}"
                                                    TextWrapping="Wrap"
                                                    FontWeight="Bold" Padding="5" />

                                                <ItemsControl ItemsSource="{Binding Details}" HorizontalAlignment="Stretch">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="local:TpmEntryCheckViewModel">
                                                            <Border Margin="0,0,0,5" Padding="5" CornerRadius="3"
                                                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                                    HorizontalAlignment="Stretch">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding PcrInfo}" FontWeight="Bold"/>
                                                                    <TextBlock Text="{Binding EventHex}" FontFamily="Consolas"/>
                                                                    <TextBlock Text="{Binding ExpectedHex}" FontFamily="Consolas"/>
                                                                    <TextBlock Text="{Binding ActualHex}" FontFamily="Consolas"/>
                                                                    <TextBlock Text="{Binding StatusText}" FontStyle="Italic"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>

                                    <DataTemplate DataType="local:GdsResultViewModel">
                                        <Expander IsExpanded="{Binding IsExpanded}" HorizontalAlignment="Stretch">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding StageName}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding StageResult, Converter={StaticResource BoolToStatusTextConverter}}"
                                                            Foreground="{Binding StageResult, Converter={StaticResource BoolToColorConverter}}"/>
                                                </StackPanel>
                                            </Expander.Header>

                                            <TextBlock Text="{Binding ErrorMessage}" 
                                                    TextWrapping="Wrap"
                                                    Foreground="{Binding StageResult, Converter={StaticResource BoolToColorConverter}}" 
                                                    FontWeight="Bold" Padding="5" />
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.DataTemplates>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Certificate Self-Management">
            <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">

                <TextBlock Grid.Row="0" Text="GDS Endpoint"/>
                <TextBox Grid.Row="1" Name="GdsEndpointInput" Watermark="Enter GDS Endpoint" Text="opc.tcp://localhost:58810/GlobalDiscoveryServer/"/>

                <TextBlock Grid.Row="2" Text="GDS Username" Margin="0,8,0,0"/>
                <TextBox Grid.Row="3" Name="GdsUsernameInput" Watermark="Enter GDS username"/>

                <TextBlock Grid.Row="4" Text="GDS Password" Margin="0,8,0,0"/>
                <TextBox PasswordChar="*" Grid.Row="5" Name="GdsPasswordInput" Watermark="Enter GDS password"/>

                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                    <Button Content="Get Certificate" Click="GetCertificate_Click"/>
                </StackPanel>

                <Grid Grid.Row="8"/>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
